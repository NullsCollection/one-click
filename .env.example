# =============================================================================
# ONE-CLICK FRONTEND — Environment Variables
# Copy this file to .env.local and fill in real values.
# This file is the source of truth — keep it up to date.
# =============================================================================

# Backend API base URL (no trailing slash)
# Local development: http://localhost:8080
# Production: https://api.yourdomain.com
NEXT_PUBLIC_API_URL=http://localhost:8080

# Cal.com booking link for the onboarding setup call
# Format: your-username/event-name (from cal.com/your-username/event-name)
NEXT_PUBLIC_CAL_LINK=your-username/setup-call

# n8n webhook URL — triggered when a user successfully books their setup call.
# The webhook receives: { name, email, booking (Cal.com data), onboarding (Yes/No answers) }

N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/your-webhook-id
